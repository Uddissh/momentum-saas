# ──────────────────────────────────────────
# Momentum SaaS — Environment Variables
# Copy this file to .env and fill in values
# ──────────────────────────────────────────

# Supabase — get from https://supabase.com/dashboard/project/<your-project>/settings/api
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Anthropic API — get from https://console.anthropic.com
# Used by the AI Insights page (client-side call)
# For production: proxy this through a backend to keep key secret
VITE_ANTHROPIC_API_KEY=sk-ant-your-key-here
